# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore virtual environments
venv/
env/
.venv/
.env/

# Ignore data files and datasets
data/
dataset/
*.csv
*.tsv
*.json
*.xlsx
*.h5
*.npz
*.npy

# Ignore model outputs and checkpoints
outputs/
results/
checkpoints/
*.ckpt
*.pth
*.pt
*.hdf5

# Ignore logs and temporary files
*.log
*.tmp
*.bak

# Ignore files generated by running code
*.out
*.run
*.cache